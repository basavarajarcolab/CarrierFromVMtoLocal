<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SAP ↔ DMS Integration — Technical Proposal</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --white:#ffffff;--off-white:#f8f7f4;--light:#f0ede8;--rule:#ddd9d2;--muted:#9b9488;
  --body:#3d3a34;--heading:#1a1814;--ink:#0f0e0c;
  --blue:#1a4480;--blue-light:#e8eef7;--blue-mid:#c5d4ea;
  --orange:#b84a0e;--orange-light:#fdf0ea;--orange-mid:#f0c9b5;
  --green:#1a6140;--green-light:#e8f5ee;--red:#911a1a;--red-light:#fdf0f0;
  --purple:#4a1a80;--purple-light:#f0e8f7;--gold:#8a6a00;--gold-light:#fdf8e8;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--off-white);color:var(--body);font-family:'DM Sans',sans-serif;font-weight:400;line-height:1.7;font-size:14px;-webkit-font-smoothing:antialiased}
@media print {
  /* ── basics ── */
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  .no-print{display:none!important}
  html,body{background:white!important;margin:0;padding:0;font-size:11px}

  /* ── page setup ── */
  @page{size:A4;margin:18mm 16mm 18mm 16mm}
  @page:first{margin-top:0;margin-bottom:0}

  /* ── cover page ── */
  .cover{min-height:0;height:297mm;page-break-after:always;display:flex;flex-direction:column;justify-content:space-between}
  .cover-top{padding:40px 52px 0}
  .cover-body{padding:0 52px;margin-top:60px}
  .cover-bottom{padding:24px 52px 40px;margin-top:auto}

  /* ── nav bar hidden ── */
  .toc-bar{display:none!important}

  /* ── main container ── */
  .main{max-width:100%;padding:0;margin:0}

  /* ── prevent orphaned section headings ── */
  .section{padding-top:32px;page-break-inside:avoid}
  .section-heading{page-break-after:avoid}
  .section-lead{page-break-after:avoid}
  h3.sub,h3.subsm{page-break-after:avoid}

  /* ── keep cards together ── */
  .opt-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;page-break-inside:avoid}
  .opt-card{page-break-inside:avoid;border:1px solid #ddd!important}
  .kpi-row{page-break-inside:avoid}
  .exec-box{page-break-inside:avoid}

  /* ── flow diagrams ── */
  .flow-wrap{page-break-inside:avoid;margin-bottom:24px;border:1px solid #ddd!important}
  .flow-bd{padding:18px}
  .flow-steps{display:flex!important;overflow:visible!important;flex-wrap:nowrap;gap:0}
  .fstep{min-width:0;flex:1}
  .sbox{padding:10px 7px}
  .sicon{font-size:18px}
  .stitle{font-size:9px}
  .sdetail{font-size:9px}
  .sbadge{font-size:7px}
  .farrow{width:22px;padding-top:34px}
  .flow-notes{grid-template-columns:1fr 1fr;gap:10px;margin-top:14px;padding-top:14px}
  .fnote{padding:10px 13px;font-size:10px}

  /* ── decision table ── */
  .cmp-tbl{page-break-inside:avoid;font-size:11px}
  .cmp-tbl thead th{padding:9px 11px}
  .cmp-tbl td{padding:8px 11px}

  /* ── tech stack ── */
  .tech-grid{grid-template-columns:1fr 1fr;gap:14px;page-break-inside:avoid}
  .tech-card{page-break-inside:avoid;border:1px solid #ddd!important}
  .tech-card-bd{padding:14px 18px}
  .tech-row{margin-bottom:10px;padding-bottom:10px}
  .pro-con-row{gap:6px}
  .pi,.ci{font-size:10px}
  .abox{page-break-inside:avoid;font-size:11px}

  /* ── scenario pairs ── */
  .sc-pair{gap:12px;page-break-inside:avoid}
  .sc-card{page-break-inside:avoid;border:1px solid #ddd!important}
  .sc-bd{padding:12px 15px}
  .tr-row{margin-bottom:5px}
  .sc-verdict{padding:8px 11px;font-size:10px}

  /* ── when to use ── */
  .when-grid{gap:14px;page-break-inside:avoid}
  .when-card{page-break-inside:avoid;border:1px solid #ddd!important}
  .when-bd{padding:12px 18px}
  .wi{font-size:11px;margin-bottom:6px}

  /* ── Q&A ── */
  .qa-grid{grid-template-columns:1fr 1fr;gap:14px}
  .qa-box{page-break-inside:avoid;border:1px solid #ddd!important}
  .qa-box-bd{padding:13px 15px}
  .qa-text{font-size:13px}
  .qa-context{font-size:11px}

  /* ── footer ── */
  .doc-footer{padding:22px 32px;margin-top:32px}
  .footer-brand{font-size:14px}

  /* ── schema code blocks ── */
  .schema{page-break-inside:avoid}
  .schema pre{font-size:9px}
}

/* ── COVER ── */
.cover{background:var(--ink);color:var(--white);min-height:100vh;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden}
.cover-accent{position:absolute;top:0;right:0;width:500px;height:500px;background:radial-gradient(ellipse at top right,rgba(26,68,128,.3) 0%,transparent 65%);pointer-events:none}
.cover-top{padding:56px 72px 0;display:flex;justify-content:space-between;align-items:flex-start}
.cover-logo{font-family:'DM Mono',monospace;font-size:12px;color:rgba(255,255,255,.4);letter-spacing:.15em;text-transform:uppercase}
.cover-docnum{font-family:'DM Mono',monospace;font-size:11px;color:rgba(255,255,255,.3);letter-spacing:.1em;text-align:right;line-height:1.8}
.cover-body{padding:0 72px;position:relative;z-index:1;margin-top:80px}
.cover-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(26,68,128,.5);border:1px solid rgba(26,68,128,.8);color:#93b4e0;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.25em;text-transform:uppercase;padding:6px 14px;margin-bottom:36px}
.cover-tag::before{content:'';width:6px;height:6px;border-radius:50%;background:#93b4e0;animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.cover-title{font-family:'Libre Baskerville',serif;font-size:clamp(40px,5.5vw,72px);font-weight:700;line-height:1.0;letter-spacing:-.02em;color:var(--white);margin-bottom:6px}
.cover-title-sub{font-family:'Libre Baskerville',serif;font-size:clamp(22px,3vw,40px);font-weight:400;font-style:italic;color:rgba(255,255,255,.4);margin-bottom:40px}
.cover-divider{width:72px;height:2px;background:var(--blue);margin-bottom:28px}
.cover-summary{max-width:560px;font-size:15px;color:rgba(255,255,255,.55);line-height:1.8;font-weight:300}
.cover-pills{display:flex;gap:10px;flex-wrap:wrap;margin-top:32px}
.cover-pill{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.65);font-size:11px;padding:6px 14px;font-family:'DM Mono',monospace;letter-spacing:.04em}
.cover-bottom{padding:32px 72px 52px;display:flex;justify-content:space-between;align-items:flex-end;border-top:1px solid rgba(255,255,255,.08);position:relative;z-index:1;margin-top:60px}
.cover-meta{font-size:11px;color:rgba(255,255,255,.35);line-height:2.1;font-family:'DM Mono',monospace}
.cover-meta strong{color:rgba(255,255,255,.6);font-weight:500}
.cover-opts{display:flex;gap:14px}
.opt-tag{padding:10px 18px;font-size:11px;font-family:'DM Mono',monospace;letter-spacing:.06em;text-align:center;line-height:1.4}
.opt-tag small{display:block;font-size:9px;letter-spacing:.15em;text-transform:uppercase;margin-bottom:2px;opacity:.7}
.opt-tag.o1{background:var(--blue);color:white}
.opt-tag.o2{border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.45)}

/* ── NAV ── */
.toc-bar{background:var(--white);border-bottom:1px solid var(--rule);position:sticky;top:0;z-index:100;display:flex;justify-content:center}
.toc-inner{display:flex;overflow-x:auto;-ms-overflow-style:none;scrollbar-width:none}
.toc-inner::-webkit-scrollbar{display:none}
.toc-link{display:block;padding:13px 20px;font-size:12px;font-weight:500;color:var(--muted);text-decoration:none;white-space:nowrap;border-bottom:2px solid transparent;transition:all .2s;letter-spacing:.02em}
.toc-link:hover{color:var(--heading);border-bottom-color:var(--rule)}
.toc-link.active{color:var(--blue);border-bottom-color:var(--blue)}

/* ── MAIN ── */
.main{max-width:1100px;margin:0 auto;padding:0 48px 100px}
.section{padding-top:68px}
.eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.eyebrow-n{font-family:'DM Mono',monospace;font-size:10px;color:var(--blue);background:var(--blue-light);border:1px solid var(--blue-mid);padding:3px 10px;letter-spacing:.1em}
.eyebrow-l{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);letter-spacing:.2em;text-transform:uppercase}
.section-heading{font-family:'Libre Baskerville',serif;font-size:29px;font-weight:700;color:var(--heading);line-height:1.2;letter-spacing:-.02em;margin-bottom:12px}
.section-lead{font-size:14px;color:var(--muted);max-width:680px;line-height:1.8;margin-bottom:32px}
.section-rule{height:1px;background:var(--rule);margin-bottom:32px}

/* ── EXEC SUMMARY ── */
.exec-box{background:var(--blue);color:white;padding:32px 40px;margin-bottom:32px;position:relative;overflow:hidden}
.exec-box::before{content:'"';position:absolute;right:28px;top:-16px;font-family:'Libre Baskerville',serif;font-size:150px;color:rgba(255,255,255,.05);line-height:1}
.exec-box p{font-size:15px;line-height:1.8;font-weight:300;max-width:700px;position:relative;z-index:1}
.exec-box strong{font-weight:600;color:#93b4e0}
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule);margin-bottom:40px}
.kpi{background:var(--white);padding:20px 22px;text-align:center}
.kpi-v{font-family:'Libre Baskerville',serif;font-size:26px;font-weight:700;color:var(--heading);line-height:1;margin-bottom:4px}
.kpi-l{font-size:10px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;font-family:'DM Mono',monospace}

/* ── OPTION CARDS ── */
.opt-cards{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:40px}
.opt-card{border:1px solid var(--rule);background:var(--white);overflow:hidden}
.opt-card-hd{padding:20px 24px;border-bottom:1px solid var(--rule);display:flex;align-items:flex-start;justify-content:space-between;gap:14px}
.opt-card.o1 .opt-card-hd{background:var(--blue-light);border-bottom-color:var(--blue-mid)}
.opt-card.o2 .opt-card-hd{background:var(--orange-light);border-bottom-color:var(--orange-mid)}
.opt-card-n{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:4px}
.o1 .opt-card-n{color:var(--blue)}.o2 .opt-card-n{color:var(--orange)}
.opt-card-nm{font-family:'Libre Baskerville',serif;font-size:17px;font-weight:700;color:var(--heading);line-height:1.3}
.opt-rec{font-size:9px;letter-spacing:.15em;text-transform:uppercase;padding:4px 10px;white-space:nowrap;font-family:'DM Mono',monospace;flex-shrink:0;align-self:flex-start}
.o1 .opt-rec{background:var(--blue);color:white}.o2 .opt-rec{border:1px solid var(--orange);color:var(--orange)}
.opt-card-bd{padding:20px 24px}
.opt-desc{font-size:13px;color:var(--body);line-height:1.7;margin-bottom:16px}
.opt-path{background:var(--off-white);border:1px solid var(--rule);padding:11px 14px;font-family:'DM Mono',monospace;font-size:11px;color:var(--body);line-height:1.8}

/* ── DECISION TABLE ── */
.cmp-tbl{width:100%;border-collapse:collapse;font-size:13px;margin-bottom:32px}
.cmp-tbl thead tr{background:var(--off-white)}
.cmp-tbl thead th{padding:11px 15px;text-align:left;font-size:11px;letter-spacing:.06em;text-transform:uppercase;font-family:'DM Sans',sans-serif;font-weight:600;color:var(--heading);border-bottom:2px solid var(--rule)}
.cmp-tbl thead th:nth-child(2){border-bottom-color:var(--blue);color:var(--blue)}
.cmp-tbl thead th:nth-child(3){border-bottom-color:var(--orange);color:var(--orange)}
.cmp-tbl tbody tr{border-bottom:1px solid var(--rule)}
.cmp-tbl tbody tr:hover{background:var(--off-white)}
.cmp-tbl td{padding:11px 15px;vertical-align:middle}
.cmp-tbl td:first-child{color:var(--heading);font-weight:500}
.cmp-tbl td:nth-child(2){color:var(--blue)}.cmp-tbl td:nth-child(3){color:var(--orange)}
.bg{padding:2px 7px;font-size:10px;font-family:'DM Mono',monospace}
.bg-g{background:var(--green-light);color:var(--green)}.bg-w{background:var(--gold-light);color:var(--gold)}.bg-r{background:var(--red-light);color:var(--red)}

/* ── FLOW DIAGRAMS ── */
.flow-wrap{border:1px solid var(--rule);background:var(--white);margin-bottom:40px;overflow:hidden}
.flow-hd{padding:16px 26px;border-bottom:1px solid var(--rule);display:flex;align-items:center;justify-content:space-between}
.flow-wrap.fw1 .flow-hd{background:var(--blue-light)}
.flow-wrap.fw2 .flow-hd{background:var(--orange-light)}
.flow-title{font-family:'Libre Baskerville',serif;font-size:15px;font-weight:700;color:var(--heading)}
.flow-badge{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;padding:4px 11px}
.fw1 .flow-badge{background:var(--blue);color:white}.fw2 .flow-badge{background:var(--orange);color:white}
.flow-bd{padding:28px}
.flow-steps{display:flex;align-items:flex-start;overflow-x:auto;padding-bottom:4px;gap:0}
.fstep{flex:1;min-width:115px;max-width:160px;display:flex;flex-direction:column;align-items:center;text-align:center}
.sbox{width:100%;padding:14px 10px;border:1px solid var(--rule);background:var(--off-white);transition:all .2s;cursor:default}
.sbox:hover{box-shadow:0 4px 14px rgba(0,0,0,.07);transform:translateY(-2px)}
.fw1 .sbox:hover{border-color:var(--blue)}.fw2 .sbox:hover{border-color:var(--orange)}
.snum{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.sicon{font-size:22px;display:block;margin-bottom:8px}
.stitle{font-family:'DM Sans',sans-serif;font-size:10px;font-weight:700;color:var(--heading);margin-bottom:4px;text-transform:uppercase;letter-spacing:.03em}
.sdetail{font-size:10px;color:var(--muted);line-height:1.45}
.sbadge{display:inline-block;margin-top:7px;font-family:'DM Mono',monospace;font-size:8px;padding:2px 6px;letter-spacing:.06em}
.fw1 .sbadge{background:var(--blue-light);color:var(--blue);border:1px solid var(--blue-mid)}
.fw2 .sbadge{background:var(--orange-light);color:var(--orange);border:1px solid var(--orange-mid)}
/* SQS special node */
.sqs-s .sbox{border-color:var(--purple);border-style:dashed;background:var(--purple-light)}
.sqs-s .stitle{color:var(--purple)}
.sqs-s .sbadge{background:var(--purple-light);color:var(--purple);border:1px solid rgba(74,26,128,.2)}
/* Lambda special node */
.lmb-s .sbox{border-color:var(--green);background:var(--green-light)}
.lmb-s .stitle{color:var(--green)}
.lmb-s .sbadge{background:var(--green-light);color:var(--green);border:1px solid rgba(26,97,64,.2)}
/* End node */
.end-s .sbox{border-color:var(--heading);background:var(--heading)}
.end-s .stitle{color:white}.end-s .sdetail{color:rgba(255,255,255,.6)}
.end-s .sbadge{background:rgba(255,255,255,.1);color:white;border:1px solid rgba(255,255,255,.2)}
/* Arrow */
.farrow{display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding-top:40px;width:28px;flex-shrink:0}
.aline{width:1px;height:20px}
.fw1 .aline{background:var(--blue)}.fw2 .aline{background:var(--orange)}
.ahead{width:0;height:0}
.fw1 .ahead{border-top:5px solid var(--blue);border-left:3px solid transparent;border-right:3px solid transparent}
.fw2 .ahead{border-top:5px solid var(--orange);border-left:3px solid transparent;border-right:3px solid transparent}
.alabel{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.06em;text-transform:uppercase;margin-top:3px;writing-mode:vertical-rl;text-orientation:mixed;transform:rotate(180deg);white-space:nowrap}
.fw1 .alabel{color:var(--blue)}.fw2 .alabel{color:var(--orange)}
/* Flow notes */
.flow-notes{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:20px;border-top:1px solid var(--rule);padding-top:20px}
.fnote{padding:13px 16px;font-size:12px;line-height:1.6;border-left:3px solid}
.fnote.pos{background:var(--green-light);border-color:var(--green)}
.fnote.inf{background:var(--blue-light);border-color:var(--blue)}
.fnote.neg{background:var(--red-light);border-color:var(--red)}
.fnote.cau{background:var(--gold-light);border-color:var(--gold)}
.fnote strong{display:block;font-weight:600;margin-bottom:3px;font-size:10px;letter-spacing:.05em;text-transform:uppercase}
.fnote.pos strong{color:var(--green)}.fnote.inf strong{color:var(--blue)}
.fnote.neg strong{color:var(--red)}.fnote.cau strong{color:var(--gold)}
.fnote span{color:var(--body)}

/* ── TECH STACK ── */
.tech-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px}
.tech-card{border:1px solid var(--rule);background:var(--white);overflow:hidden}
.tech-card-hd{padding:16px 22px;border-bottom:1px solid var(--rule);display:flex;align-items:center;justify-content:space-between;gap:12px}
.tech-card.tc1 .tech-card-hd{background:var(--blue-light);border-bottom-color:var(--blue-mid)}
.tech-card.tc2 .tech-card-hd{background:var(--orange-light);border-bottom-color:var(--orange-mid)}
.tech-card-title{font-family:'Libre Baskerville',serif;font-size:15px;font-weight:700;color:var(--heading)}
.tech-ver{font-family:'DM Mono',monospace;font-size:10px;padding:3px 9px;letter-spacing:.08em}
.tc1 .tech-ver{background:var(--blue);color:white}.tc2 .tech-ver{background:var(--orange);color:white}
.tech-card-bd{padding:18px 22px}
.tech-row{margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid var(--rule)}
.tech-row:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.tech-component{font-family:'DM Mono',monospace;font-size:12px;font-weight:500;color:var(--heading);margin-bottom:4px;display:flex;align-items:center;gap:8px}
.tech-ver-inline{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);background:var(--off-white);border:1px solid var(--rule);padding:1px 7px}
.tech-install-label{font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;margin-top:6px;font-family:'DM Mono',monospace}
.pro-con-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:7px}
.pi,.ci{display:flex;gap:6px;font-size:11px;line-height:1.5;color:var(--body)}
.pi::before{content:'+';color:var(--green);font-weight:700;flex-shrink:0;width:11px}
.ci::before{content:'−';color:var(--red);font-weight:700;flex-shrink:0;width:11px}

/* ── SCENARIOS ── */
.sc-pair{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:26px}
.sc-card{border:1px solid var(--rule);background:var(--white);overflow:hidden}
.sc-hd{padding:13px 18px;border-bottom:1px solid var(--rule);display:flex;align-items:center;gap:9px}
.sc-hd.suc{background:var(--green-light)}.sc-hd.fail{background:var(--red-light)}
.sc-icon{font-size:15px}
.sc-title{font-size:13px;font-weight:600;color:var(--heading)}
.sc-sub{font-family:'DM Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:.05em;margin-top:1px}
.sc-bd{padding:16px 18px}
.tr-row{display:flex;gap:11px;margin-bottom:6px;font-size:12px;line-height:1.4;align-items:flex-start}
.t-time{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);width:64px;flex-shrink:0;padding-top:1px}
.t-ev{color:var(--body)}.t-good{color:var(--green);font-weight:500}.t-bad{color:var(--red);font-weight:500}
.sc-verdict{margin-top:12px;padding:10px 13px;font-size:11px;font-family:'DM Mono',monospace;line-height:1.9}
.sc-card.suc .sc-verdict{background:var(--green-light);color:var(--green);border:1px solid rgba(26,97,64,.15)}
.sc-card.fail .sc-verdict{background:var(--red-light);color:var(--red);border:1px solid rgba(145,26,26,.15)}

/* ── WHEN TO USE ── */
.when-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px}
.when-card{border:1px solid var(--rule);overflow:hidden;background:var(--white)}
.when-hd{padding:15px 22px;border-bottom:1px solid var(--rule)}
.when-card.wc1 .when-hd{background:var(--blue-light);border-bottom-color:var(--blue-mid)}
.when-card.wc2 .when-hd{background:var(--orange-light);border-bottom-color:var(--orange-mid)}
.when-hd-t{font-family:'Libre Baskerville',serif;font-size:14px;font-weight:700;color:var(--heading)}
.when-bd{padding:16px 22px}
